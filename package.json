{
  "name": "vanity-number-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Amazon Connect vanity phone number generator using CDK, Lambda, DynamoDB, AppSync, CloudFront, and S3.",
  "bin": {
    "vanity-number-generator": "bin/vanity-number-generator.ts"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:infra": "jest --testMatch \"**/test/infrastructure/**/*.test.ts\"",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1042.0",
    "@aws-sdk/lib-dynamodb": "^3.1042.0",
    "aws-cdk-lib": "^2.252.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "aws-cdk": "^2.1118.2",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
